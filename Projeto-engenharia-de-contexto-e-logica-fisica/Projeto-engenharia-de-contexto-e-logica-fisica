# --- Configuração da Casa e Regras de Evacuação ---
layout_casa = {
    'Quarto 1': {'conecta': 'Sala/Cozinha', 'chave': True},
    'Quarto 2': {'conecta': 'Sala/Cozinha', 'chave': True, 'emergencia': 'Varanda'},
    'Sala/Cozinha': {'conecta': 'SAIDA_PRINCIPAL', 'chave': False},
    'Banheiro': {'conecta': 'Sala/Cozinha', 'chave': False},
    'Varanda': {'conecta': 'RUA', 'risco': 'ALTO'}
}

def plano_evacuacao(local_atual, inventario, energia):
    print(f"--- Iniciando evacuação de: {local_atual} ---")
    
    # 1. Tentar Saída Principal pela Sala
    if local_atual == 'Sala/Cozinha':
        print("Caminho livre! Saída principal alcançada.")
        return True
    
    # 2. Verificar se está em um quarto com chave
    info = layout_casa[local_atual]
    if info['chave'] and 'chave_casa' not in inventario:
        print(f"Alerta: Você precisa pegar a chave no {local_atual} primeiro!")
        inventario.append('chave_casa')
    
    # 3. Lógica Crítica: Varanda (Quarto 2)
    if 'emergencia' in info:
        print(f"Caminho alternativo detectado: {info['emergencia']}")
        if energia < 50:
            print("Energia BAIXA. Pular da varanda é muito arriscado! Tente a Sala.")
        else:
            print("Energia SUFICIENTE. Evacuação de emergência pela varanda realizada com sucesso (Risco de acidente).")
            return True

    # 4. Movimentação para a Sala
    proximo_passo = info['conecta']
    print(f"Movendo de {local_atual} para {proximo_passo}...")
    return plano_evacuacao(proximo_passo, inventario, energia)

# --- Teste de Simulação ---
meu_inventario = []
minha_energia = 70  # Altere para < 50 para ver a mudança de comportamento

plano_evacuacao('Quarto 2', meu_inventario, minha_energia)


